# ========================================
# Variables de Entorno - Ejemplo
# ========================================
# Copia este archivo a .env y completa los valores
# NO SUBIR .env a Git (ya está en .gitignore)

# === SEGURIDAD ===
# Clave secreta para sesiones Flask (generar una nueva para producción)
SECRET_KEY=tu-clave-secreta-aleatorea-muy-larga

# Contraseña del administrador por defecto
# ⚠️ IMPORTANTE: Cambiar en producción
ADMIN_PASSWORD=IPSD@admin2026

# === BASE DE DATOS ===
# URL de conexión a PostgreSQL
# Ejemplo local: postgresql://usuario:password@localhost:5434/sistema_unah
# Ejemplo producción: postgresql://postgres:mypassword@db.host.com:5434/sistema_unah
DATABASE_URL=postgresql://postgres:Postgre202625@localhost:5434/sistema_unah

# === ENTORNO ===
# Modo de aplicación (development o production)
FLASK_ENV=production

# === DEBUG (Solo en desarrollo, NUNCA en producción) ===
# FLASK_DEBUG=False
